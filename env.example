# ② Spring EC2 /opt/spring/.env 샘플 — 실제 값은 EC2에만 둔다(커밋 금지)
# Actions 배포 시 ECR_REGISTRY는 워크플로가 주입. 수동 기동 시 아래 값 사용.

# ===== ECR (수동 docker compose 기동 시 필요) =====
ECR_REGISTRY=143924590342.dkr.ecr.ap-northeast-2.amazonaws.com

# ===== Spring 프로파일 =====
SPRING_PROFILES_ACTIVE=deploy
# 첫 부팅만 update로 테이블 생성 → 정상 확인 후 이 줄 삭제(=validate로 고정)
DDL_AUTO=update

# ===== DB (새 RDS codebomb) =====
DB_URL=jdbc:mysql://codebomb-rds.cb48qiuki6pn.ap-northeast-2.rds.amazonaws.com:3306/codebomba?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=<RDS_MASTER_USER>
DB_PASSWORD=<RDS_MASTER_PASSWORD>

# ===== Redis (③ 모니터링 EC2 사설IP, requirepass) =====
REDIS_HOST=<③_MONITORING_PRIVATE_IP>
REDIS_PORT=6379
REDIS_PASSWORD=<③_REDIS_PASSWORD>

# ===== Loki (③ 모니터링 EC2 사설IP — promtail이 로그 push) =====
# REDIS_HOST와 같은 박스(③). promtail-config.yml의 ${LOKI_HOST} 치환에 쓰임
LOKI_HOST=<③_MONITORING_PRIVATE_IP>

# ===== CORS 허용 오리진 (① 프론트, 콤마 구분) =====
CORS_ALLOWED_ORIGINS=http://13.125.139.116:3000,http://localhost:3001

# ===== FastAPI 챗봇 (④ EC2 사설IP) =====
FASTAPI_URL=http://<CHATBOT_PRIVATE_IP>:8000

# ===== JWT =====
JWT_SECRET=<JWT_SECRET_BASE64>

# ===== Mail (Gmail SMTP) =====
MAIL_USERNAME=<...@gmail.com>
MAIL_PASSWORD=<앱비밀번호>

# ===== Google OAuth =====
GOOGLE_CLIENT_ID=<...>
GOOGLE_CLIENT_SECRET=<...>
GOOGLE_REDIRECT_URI=https://<API_DOMAIN>/api/v1/auth/oauth2/callback/google

# ===== OAuth 콜백 redirect (① 프론트) =====
OAUTH_ADDITIONAL_INFO_URI=http://<FE_HOST>/oauth2/additional-info
OAUTH_SUCCESS_URI=http://<FE_HOST>

# ===== Cookie (운영 https면 true) =====
COOKIE_SECURE=true

# ===== GCP Storage =====
GCP_PROJECT_ID=<...>
GCP_STORAGE_BUCKET=codebombalms
# 키 파일은 EC2 /opt/spring/secrets/gcp-storage-key.json 에 두고 컨테이너에 마운트
GCP_CREDENTIALS_LOCATION=file:/app/secrets/gcp-storage-key.json
