@baseUrl = http://localhost:8080
@categoryId = 2001
@problemSetId = 2001
@completedProblemSetId = 2001
@codeProblemSetId = 3001
@codeProblemId = 3001
@connectedDatasetId = 3001
@textProblemId = 2001
@userId = 4
@completedUserId = 3
@manageProblemSetId = 2002

### 1. 카테고리 목록 조회
GET {{baseUrl}}/api/v1/problem-categories
Accept: application/json


### 2. 문제 세트 목록 조회
GET {{baseUrl}}/api/v1/problem-sets?categoryId={{categoryId}}
Accept: application/json


### 3. 문제 세트 목록 조회 실패 - 없는 카테고리
GET {{baseUrl}}/api/v1/problem-sets?categoryId=999999
Accept: application/json


### 4. 문제 세트 진입 - 진행 중 사용자
GET {{baseUrl}}/api/v1/problem-sets/{{problemSetId}}?userId={{userId}}
Accept: application/json


### 5. 문제 세트 진입 - 완료 사용자
GET {{baseUrl}}/api/v1/problem-sets/{{completedProblemSetId}}?userId={{completedUserId}}
Accept: application/json


### 6. 코드 문제 세트 진입 - 시작 코드 확인
GET {{baseUrl}}/api/v1/problem-sets/{{codeProblemSetId}}?userId={{userId}}
Accept: application/json


### 7. 문제 세트 진입 실패 - 없는 문제 세트
GET {{baseUrl}}/api/v1/problem-sets/999999?userId={{userId}}
Accept: application/json


### 8. 진행 상태 조회 - 진행 중 사용자
GET {{baseUrl}}/api/v1/problem-sets/{{problemSetId}}/progress?userId={{userId}}
Accept: application/json


### 9. 진행 상태 조회 - 완료 사용자
GET {{baseUrl}}/api/v1/problem-sets/{{completedProblemSetId}}/progress?userId={{completedUserId}}
Accept: application/json


### 10. 진행 상태 조회 실패 - 없는 문제 세트
GET {{baseUrl}}/api/v1/problem-sets/999999/progress?userId={{userId}}
Accept: application/json


### 11. 결과 조회 - 완료 사용자
GET {{baseUrl}}/api/v1/problem-sets/{{completedProblemSetId}}/result?userId={{completedUserId}}
Accept: application/json


### 12. 결과 조회 실패 - 미완료 사용자
GET {{baseUrl}}/api/v1/problem-sets/{{problemSetId}}/result?userId={{userId}}
Accept: application/json


### 13. 결과 조회 실패 - 없는 문제 세트
GET {{baseUrl}}/api/v1/problem-sets/999999/result?userId={{userId}}
Accept: application/json


### 14. 데이터셋 업로드
# 16번에서 사용할 새 데이터셋을 생성합니다.
POST {{baseUrl}}/api/v1/problem-datasets
Accept: application/json
Content-Type: multipart/form-data; boundary=datasetBoundary

--datasetBoundary
Content-Disposition: form-data; name="datasetFile"; filename="clean_architecture_dataset.csv"
Content-Type: text/csv

id,value
1,100
2,200
--datasetBoundary--

> {%
    client.global.set("cleanArchitectureDatasetId", response.body.data.datasetId);
%}


### 15. 데이터셋 업로드 실패 - CSV가 아닌 파일
POST {{baseUrl}}/api/v1/problem-datasets
Accept: application/json
Content-Type: multipart/form-data; boundary=invalidDatasetBoundary

--invalidDatasetBoundary
Content-Disposition: form-data; name="datasetFile"; filename="clean_architecture_dataset.txt"
Content-Type: text/plain

not,csv,file
--invalidDatasetBoundary--


### 16. 문제-데이터셋 연결
# 사전 조건: 14번을 먼저 실행해서 cleanArchitectureDatasetId가 있어야 합니다.
POST {{baseUrl}}/api/v1/problems/{{codeProblemId}}/datasets
Accept: application/json
Content-Type: application/json

{
  "datasetId": {{cleanArchitectureDatasetId}}
}


### 17. 문제-데이터셋 연결 실패 - 이미 연결된 데이터셋
# 사전 조건: 16번을 먼저 실행해서 같은 데이터셋이 이미 연결된 상태여야 합니다.
POST {{baseUrl}}/api/v1/problems/{{codeProblemId}}/datasets
Accept: application/json
Content-Type: application/json

{
  "datasetId": {{cleanArchitectureDatasetId}}
}


### 18-1. 텍스트 문제 연결 실패 테스트용 데이터셋 업로드
POST {{baseUrl}}/api/v1/problem-datasets
Accept: application/json
Content-Type: multipart/form-data; boundary=textProblemDatasetBoundary

--textProblemDatasetBoundary
Content-Disposition: form-data; name="datasetFile"; filename="text_problem_dataset.csv"
Content-Type: text/csv

id,value
1,100
--textProblemDatasetBoundary--

> {%
    client.global.set("textProblemDatasetId", response.body.data.datasetId);
%}


### 18. 문제-데이터셋 연결 실패 - 코드 문제가 아님
POST {{baseUrl}}/api/v1/problems/{{textProblemId}}/datasets
Accept: application/json
Content-Type: application/json

{
  "datasetId": {{textProblemDatasetId}}
}


### 19. 문제 세트 등록
POST {{baseUrl}}/api/v1/problems
Accept: application/json
Content-Type: application/json

{
  "title": "클린 아키텍처 등록 테스트",
  "categoryName": "클린 아키텍처",
  "description": "패키지 리팩토링 후 등록 흐름을 확인하는 문제 세트입니다.",
  "dataFileName": null,
  "problems": [
    {
      "title": "계층 책임",
      "content": "Controller가 직접 호출하지 않고 의존해야 하는 계층은 무엇인가요?",
      "point": 10,
      "startCode": null,
      "answer": "UseCase",
      "hint": "Application 계층의 입구입니다.",
      "explanation": "Controller는 요청을 Command나 Query로 바꾸고 UseCase를 호출합니다."
    }
  ]
}


### 20. 문제 세트 수정
POST {{baseUrl}}/api/v1/problems
Accept: application/json
Content-Type: application/json

{
  "title": "수정 테스트용 문제 세트",
  "categoryName": "데이터 분석",
  "description": "20번 수정 요청에서 사용할 문제 세트입니다.",
  "dataFileName": null,
  "problems": [
    {
      "title": "수정 전 문제",
      "content": "수정 전 내용입니다.",
      "point": 10,
      "startCode": null,
      "answer": "수정 전 정답",
      "hint": "수정 전 힌트",
      "explanation": "수정 전 해설"
    }
  ]
}

> {%
    client.global.set("createdProblemSetId", response.body.problemSetId);
    client.global.set("createdProblemId", response.body.problemSetId);
%}


### 20-1. 문제 세트 수정
# 주의: 현재 수정 API는 problemId가 필요하므로, 실제 확인은 기존 더미 데이터 manageProblemSetId를 사용합니다.
PUT {{baseUrl}}/api/v1/problems/{{manageProblemSetId}}
Accept: application/json
Content-Type: application/json

{
  "title": "집계와 지표 분석 - 클린 구조 수정",
  "categoryName": "데이터 분석",
  "description": "수정 API 리팩토링 확인 요청입니다.",
  "dataFileName": null,
  "problems": [
    {
      "problemId": 2004,
      "title": "GROUP BY 목적 - 수정",
      "content": "SQL에서 GROUP BY를 사용하는 목적을 작성하세요.",
      "point": 15,
      "startCode": null,
      "answer": "집계",
      "hintId": 2004,
      "hint": "집계 함수와 함께 자주 사용합니다.",
      "explanation": "GROUP BY는 특정 컬럼 기준으로 데이터를 묶어 집계할 때 사용합니다."
    }
  ]
}


### 21. 문제 세트 삭제 실패 - 제출 기록 존재
DELETE {{baseUrl}}/api/v1/problems/2001
Accept: application/json


### 22. 문제 세트 강제 비활성화
# 주의: 실행하면 더미 데이터 상태가 INACTIVE로 바뀝니다.
DELETE {{baseUrl}}/api/v1/problems/2001?force=true
Accept: application/json
