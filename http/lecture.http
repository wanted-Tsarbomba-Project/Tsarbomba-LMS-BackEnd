### Base URL
@host = http://localhost:8080

### Test IDs
@courseId = 101
@lectureId = 101


### 1. Lecture list by course
GET {{host}}/api/v1/courses/{{courseId}}/lectures


### 2. Create lecture
POST {{host}}/api/v1/courses/{{courseId}}/lectures
Content-Type: application/json

{
  "title": "Java 1강",
  "description": "Java 기본 문법을 학습하는 강의입니다.",
  "videoUrl": "java-1.mp4",
  "thumbnailUrl": "java-1.png",
  "lectureOrder": 1,
  "status": "ACTIVE"
}


### 3. Lecture detail
GET {{host}}/api/v1/lectures/{{lectureId}}


### 4. Update lecture
PUT {{host}}/api/v1/lectures/{{lectureId}}
Content-Type: application/json

{
  "title": "수정된 Java 1강",
  "description": "수정된 강의 설명입니다.",
  "videoUrl": "updated-java-1.mp4",
  "thumbnailUrl": "updated-java-1.png",
  "lectureOrder": 1,
  "status": "INACTIVE"
}


### 5. Delete lecture
DELETE {{host}}/api/v1/lectures/{{lectureId}}


### 6. Check deleted lecture detail
GET {{host}}/api/v1/lectures/{{lectureId}}
