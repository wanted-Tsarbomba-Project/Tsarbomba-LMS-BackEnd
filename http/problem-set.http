@baseUrl = http://localhost:8080
@categoryId = 3001
@problemSetId = 3001
@userId = 3
@accessToken = PUT_REAL_ACCESS_TOKEN_HERE

@updateProblemSetId = 3001
@updateProblemId = 3001
@updateHintId = 2001

# =====================================================
# 문제 세트 조회
# =====================================================

### 1. 문제 세트 목록 조회
# 기대 결과:
# - 200 OK
# - categoryId에 속한 ACTIVE 문제 세트 목록이 조회됩니다.
GET {{baseUrl}}/api/v1/problem-sets?categoryId={{categoryId}}
Accept: application/json


### 2. 문제 세트 진입 및 현재 문제 조회 - point 확인
# 기대 결과:
# - 200 OK
# - data.problem.point 값이 내려오면 point 응답 확인 성공입니다.
# - 정답(answer)은 응답에 포함되면 안 됩니다.
GET {{baseUrl}}/api/v1/problem-sets/{{problemSetId}}?userId={{userId}}
Accept: application/json


# =====================================================
# 문제 세트 등록
# =====================================================

### 3. 문제 세트 등록 성공 - point 저장 확인용
# 기대 결과:
# - 201 Created
# - problem_set 1개, problem 2개, problem_hint 2개가 생성됩니다.
# - 각 problem의 point가 DB에 저장됩니다.
POST {{baseUrl}}/api/v1/problems
Accept: application/json
Content-Type: application/json
Cookie: accessToken={{accessToken}}

{
  "title": "pandas point 확인 문제 세트",
  "categoryName": "Python 데이터 분석",
  "description": "문제별 point가 저장되는지 확인하는 코드 실행형 문제 세트입니다.",
  "difficulty": "EASY",
  "dataFileName": "employee_performance_202605.csv",
  "problems": [
    {
      "title": "행과 열 개수 확인",
      "content": "employee_performance.csv 파일을 읽고 DataFrame의 행과 열 개수를 result에 담으세요.",
      "point": 10,
      "startCode": "import pandas as pd\n\ndf = pd.read_csv(\"uploads/datasets/employee_performance_202605.csv\")",
      "answer": "result = df.shape",
      "hint": "DataFrame의 shape 속성을 사용해보세요.",
      "explanation": "df.shape는 (행 개수, 열 개수) 형태의 튜플을 반환합니다."
    },
    {
      "title": "평균 점수 계산",
      "content": "performance_score 컬럼의 평균값을 result에 담으세요.",
      "point": 20,
      "startCode": "import pandas as pd\n\ndf = pd.read_csv(\"uploads/datasets/employee_performance_202605.csv\")",
      "answer": "result = df[\"performance_score\"].mean()",
      "hint": "Series의 mean() 메서드를 사용해보세요.",
      "explanation": "df[\"performance_score\"].mean()은 performance_score 컬럼의 평균을 계산합니다."
    }
  ]
}


### 4. 문제 세트 등록 실패 - point 누락
# 기대 결과:
# - 400 Bad Request
# - PROBLEM_INVALID_INPUT 계열 응답
POST {{baseUrl}}/api/v1/problems
Accept: application/json
Content-Type: application/json
Cookie: accessToken={{accessToken}}

{
  "title": "point 누락 테스트",
  "categoryName": "Python 데이터 분석",
  "description": "point 필수 검증 확인용 요청입니다.",
  "difficulty": "EASY",
  "dataFileName": "employee_performance_202605.csv",
  "problems": [
    {
      "title": "point 없는 문제",
      "content": "point가 없으면 등록되지 않아야 합니다.",
      "startCode": null,
      "answer": "result = 1",
      "hint": "point를 넣어야 합니다.",
      "explanation": "문제 보상값이 없으면 운영 화면과 결과 계산 기준이 흐려집니다."
    }
  ]
}


### 5. 문제 세트 등록 실패 - point가 0 이하
# 기대 결과:
# - 400 Bad Request
# - point는 양수여야 합니다.
POST {{baseUrl}}/api/v1/problems
Accept: application/json
Content-Type: application/json
Cookie: accessToken={{accessToken}}

{
  "title": "point 0 테스트",
  "categoryName": "Python 데이터 분석",
  "description": "point 양수 검증 확인용 요청입니다.",
  "difficulty": "EASY",
  "dataFileName": "employee_performance_202605.csv",
  "problems": [
    {
      "title": "point 0 문제",
      "content": "point가 0이면 등록되지 않아야 합니다.",
      "point": 0,
      "startCode": null,
      "answer": "result = 1",
      "hint": "point는 1 이상이어야 합니다.",
      "explanation": "포인트 보상값은 양수로 관리합니다."
    }
  ]
}


# =====================================================
# 문제 세트 수정
# =====================================================

### 6. 문제 세트 수정 성공 - point 수정 포함
# 기대 결과:
# - 200 OK
# - 기존 문제의 point도 함께 수정됩니다.
PUT {{baseUrl}}/api/v1/problems/{{updateProblemSetId}}
Accept: application/json
Content-Type: application/json
Cookie: accessToken={{accessToken}}

{
  "title": "pandas 기초 분석 문제 세트 수정",
  "categoryName": "Python 데이터 분석",
  "description": "문제 point 수정까지 확인하는 요청입니다.",
  "difficulty": "MEDIUM",
  "dataFileName": "employee_performance_202605.csv",
  "problems": [
    {
      "problemId": {{updateProblemId}},
      "title": "데이터 행과 열 개수 확인 수정",
      "content": "CSV 파일을 읽고 DataFrame의 행과 열 개수를 result에 담으세요.",
      "point": 15,
      "startCode": "import pandas as pd\n\ndf = pd.read_csv(\"uploads/datasets/employee_performance_202605.csv\")",
      "answer": "result = df.shape",
      "hintId": {{updateHintId}},
      "hint": "df.shape를 사용하세요.",
      "explanation": "shape 속성은 행과 열 개수를 튜플로 반환합니다."
    }
  ]
}


# =====================================================
# 문제 세트 삭제 / 비활성화
# =====================================================

### 7. 문제 세트 비활성화
# 기대 결과:
# - 200 OK
# - problem_set.status = INACTIVE
# - 연결된 problem.status = INACTIVE
DELETE {{baseUrl}}/api/v1/problems/{{problemSetId}}
Accept: application/json
Cookie: accessToken={{accessToken}}


### 8. 제출 기록이 있어도 강제 비활성화
# 기대 결과:
# - 200 OK
# - force=true이면 제출 기록이 있어도 비활성화합니다.
DELETE {{baseUrl}}/api/v1/problems/{{problemSetId}}?force=true
Accept: application/json
Cookie: accessToken={{accessToken}}