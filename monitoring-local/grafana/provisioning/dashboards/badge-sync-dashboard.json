{
  "uid": "badge-sync-bottleneck",
  "title": "Badge Sync Bottleneck",
  "tags": ["lms", "loadtest", "badge"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "k6 Badge Sync p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_http_req_duration_p95{type=\"badge_sync_once\"}",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "k6 Badge Sync p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_http_req_duration_p99{type=\"badge_sync_once\"}",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "k6 Failed Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_http_req_failed_rate{type=\"badge_sync_once\"}",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Newly Earned Badge Count Avg",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_badge_sync_newly_earned_count_avg",
          "legendFormat": "newly earned avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "green", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "k6 Badge Sync Duration p95 / p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_http_req_duration_p95{type=\"badge_sync_once\"}",
          "legendFormat": "k6 p95"
        },
        {
          "refId": "B",
          "expr": "k6_http_req_duration_p99{type=\"badge_sync_once\"}",
          "legendFormat": "k6 p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Badge Sync Internal Duration Avg",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(badge_sync_duration_seconds_sum[1m]) / clamp_min(rate(badge_sync_duration_seconds_count[1m]), 0.0001)",
          "legendFormat": "total sync avg"
        },
        {
          "refId": "B",
          "expr": "rate(badge_sync_grantable_lookup_duration_seconds_sum[1m]) / clamp_min(rate(badge_sync_grantable_lookup_duration_seconds_count[1m]), 0.0001)",
          "legendFormat": "grantable lookup avg"
        },
        {
          "refId": "C",
          "expr": "rate(badge_sync_earned_lookup_duration_seconds_sum[1m]) / clamp_min(rate(badge_sync_earned_lookup_duration_seconds_count[1m]), 0.0001)",
          "legendFormat": "earned lookup avg"
        },
        {
          "refId": "D",
          "expr": "rate(badge_sync_save_duration_seconds_sum[1m]) / clamp_min(rate(badge_sync_save_duration_seconds_count[1m]), 0.0001)",
          "legendFormat": "save avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Spring HTTP Avg Duration - Badge Sync",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(http_server_requests_seconds_sum{uri=\"/api/v1/badges/me/sync\"}[1m]) / clamp_min(rate(http_server_requests_seconds_count{uri=\"/api/v1/badges/me/sync\"}[1m]), 0.0001)",
          "legendFormat": "{{method}} {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Hikari Pool Pressure",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "expr": "hikaricp_connections_active",
          "legendFormat": "{{pool}} active"
        },
        {
          "refId": "B",
          "expr": "hikaricp_connections_pending",
          "legendFormat": "{{pool}} pending"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Badge Sync Newly Earned Count",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_badge_sync_newly_earned_count_avg",
          "legendFormat": "avg"
        },
        {
          "refId": "B",
          "expr": "k6_badge_sync_newly_earned_count_p95",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Badge Sync Valid Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_badge_sync_valid_rate_rate",
          "legendFormat": "valid"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 11,
      "type": "logs",
      "title": "Badge Sync Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 27 },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"lms\"} |= \"event=badge_sync_completed\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 12,
      "type": "logs",
      "title": "Badge Sync Error Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 27 },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"lms\"} |= \"badge\" |= \"ERROR\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
