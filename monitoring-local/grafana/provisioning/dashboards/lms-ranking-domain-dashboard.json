          },
          "expr": "sum(count_over_time({job=\"lms\"} |= \"/api/v1/rankings/points/me\" |= \"status=404\" [5m]))",
          "queryType": "range"
        }
      ]
    },
    {
      "type": "stat",
      "title": "대표 뱃지 후보 오류(5분)",
