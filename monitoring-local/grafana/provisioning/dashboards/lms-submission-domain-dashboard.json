      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(rate(submission_prepare_duration_seconds_sum[$__rate_interval]) / clamp_min(rate(submission_prepare_duration_seconds_count[$__rate_interval]), 0.0001)) or vector(0)",
          "legendFormat": ""
