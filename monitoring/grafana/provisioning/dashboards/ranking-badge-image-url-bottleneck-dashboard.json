{
  "uid": "ranking-badge-image-url-bottleneck",
  "title": "Ranking Badge Image URL Bottleneck",
  "tags": ["ranking", "badge", "signed-url", "bottleneck", "k6", "loadtest"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "1. k6 Ranking Badge Image View",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Ranking p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1000 },
              { "color": "red", "value": 2500 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_http_req_duration_p99{type=\"ranking_total_badge_image\"}",
          "legendFormat": "total p99"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Weekly Ranking p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1200 },
              { "color": "red", "value": 3000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_http_req_duration_p99{type=\"ranking_weekly_badge_image\"}",
          "legendFormat": "weekly p99"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Badge URL Present Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_ranking_badge_image_url_present_rate_rate",
          "legendFormat": "present rate"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Failed Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "refId": "A",
          "expr": "(k6_http_req_failed_rate * 100) or vector(0)",
          "legendFormat": "failed %"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "k6 p99 by Ranking Scenario",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_http_req_duration_p99{type=~\"ranking_total_badge_image|ranking_weekly_badge_image\"}",
          "legendFormat": "p99 - {{type}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Badge Image URL Count in Response",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_ranking_badge_image_url_count_p99",
          "legendFormat": "{{api}} image url count p99"
        },
        {
          "refId": "B",
          "expr": "k6_ranking_badge_distinct_image_url_count_p99",
          "legendFormat": "{{api}} distinct image url count p99"
        },
        {
          "refId": "C",
          "expr": "k6_ranking_badge_result_count_p99",
          "legendFormat": "{{api}} ranking row count p99"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "2. Server / DB View",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Spring HTTP Avg Duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (uri) (rate(http_server_requests_seconds_sum{uri=~\"/api/v1/rankings/points|/api/v1/rankings/points/weekly\"}[1m])) / sum by (uri) (rate(http_server_requests_seconds_count{uri=~\"/api/v1/rankings/points|/api/v1/rankings/points/weekly\"}[1m]))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Hikari Pool Pressure",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "hikaricp_connections_active",
          "legendFormat": "{{pool}} active"
        },
        {
          "refId": "B",
          "expr": "hikaricp_connections_pending",
          "legendFormat": "{{pool}} pending"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "3. Loki Logs",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "logs",
      "title": "Ranking Request Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 8 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"lms\"} |= \"/api/v1/rankings/points\""
        }
      ]
    },
    {
      "id": 32,
      "type": "logs",
      "title": "Ranking Badge Seed Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 8 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"lms\"} |= \"event=ranking_badge_loadtest_seed\""
        }
      ]
    }
  ]
}
