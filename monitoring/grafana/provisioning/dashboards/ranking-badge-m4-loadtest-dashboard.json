{
  "uid": "ranking-badge-m4-loadtest",
  "title": "Ranking & Badge M4 Load Test Dashboard",
  "tags": ["ranking", "badge", "reward", "m4", "k6", "loadtest"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "1. Summary",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Ranking Total p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 800 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_http_req_duration_p95{type=\"ranking_total\"}",
          "legendFormat": "ranking total p95"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Ranking Weekly p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1000 },
              { "color": "red", "value": 2500 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_http_req_duration_p95{type=\"ranking_weekly\"}",
          "legendFormat": "ranking weekly p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Badge Sync p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1000 },
              { "color": "red", "value": 3000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_http_req_duration_p95{type=\"badge_sync\"}",
          "legendFormat": "badge sync p95"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "HTTP Failed Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "refId": "A",
          "expr": "(k6_http_req_failed_rate * 100) or vector(0)",
          "legendFormat": "failed %"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "2. k6 Outside View",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP p95 by Scenario",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_http_req_duration_p95{type=~\"ranking_total|ranking_weekly|ranking_me|badge_sync|badge_list\"}",
          "legendFormat": "p95 - {{type}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HTTP p99 by Scenario",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_http_req_duration_p99{type=~\"ranking_total|ranking_weekly|ranking_me|badge_sync|badge_list\"}",
          "legendFormat": "p99 - {{type}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "RPS by Scenario",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (rate(k6_http_reqs_total{type=~\"ranking_total|ranking_weekly|ranking_me|badge_sync|badge_list\"}[1m]))",
          "legendFormat": "req/s - {{type}}"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "HTTP Failed Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "(k6_http_req_failed_rate * 100) or vector(0)",
          "legendFormat": "failed %"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "3. Business Signals",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Ranking Response Valid Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 21, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_ranking_response_valid_rate_rate",
          "legendFormat": "ranking valid"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Ranking Result Count",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 21, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_ranking_result_count_avg",
          "legendFormat": "ranking result count avg"
        }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "My Ranking Rank / Total Point",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 21, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_ranking_my_rank_avg",
          "legendFormat": "my rank avg"
        },
        {
          "refId": "B",
          "expr": "k6_ranking_total_point_avg",
          "legendFormat": "my total point avg"
        }
      ]
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Badge Response Valid Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_badge_response_valid_rate_rate",
          "legendFormat": "badge valid"
        }
      ]
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "Badge Owned / Newly Earned Count",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 28, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_badge_owned_count_avg",
          "legendFormat": "owned badge avg"
        },
        {
          "refId": "B",
          "expr": "k6_badge_newly_earned_count_avg",
          "legendFormat": "newly earned avg"
        }
      ]
    },
    {
      "id": 26,
      "type": "timeseries",
      "title": "Badge User Total Point",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 28, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_badge_total_point_avg",
          "legendFormat": "badge user total point avg"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "4. JVM / DB Pool",
      "gridPos": { "x": 0, "y": 35, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Hikari Connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 36, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "hikaricp_connections_active",
          "legendFormat": "{{pool}} active"
        },
        {
          "refId": "B",
          "expr": "hikaricp_connections_pending",
          "legendFormat": "{{pool}} pending"
        },
        {
          "refId": "C",
          "expr": "hikaricp_connections_idle",
          "legendFormat": "{{pool}} idle"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "JVM Memory Used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 36, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (area) (jvm_memory_used_bytes)",
          "legendFormat": "{{area}}"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "5. Logs",
      "gridPos": { "x": 0, "y": 43, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 41,
      "type": "logs",
      "title": "Ranking Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 44, "w": 12, "h": 8 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"lms\"} |~ \"ranking|Ranking|rankings\""
        }
      ]
    },
    {
      "id": 42,
      "type": "logs",
      "title": "Badge / Reward Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 12, "y": 44, "w": 12, "h": 8 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"lms\"} |~ \"badge|Badge|reward|Reward|point_reward\""
        }
      ]
    },
    {
      "id": 43,
      "type": "logs",
      "title": "Warnings / Errors",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 52, "w": 24, "h": 8 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"lms\", level=~\"WARN|ERROR\"} |~ \"ranking|badge|reward|point\""
        }
      ]
    }
  ]
}
